PORT=3000
NODE_ENV=production

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_STATE_TABLE=holobox_state

# Nếu bỏ trống, server sẽ tự dùng row đầu tiên trong holobox_state.
# Nếu muốn ép dùng row id = main thì để main.
SUPABASE_STATE_ID=main

# Supabase Storage bucket
SUPABASE_BUCKET=holobox-media

# 250MB mặc định. Tăng nếu cần upload file lớn hơn.
UPLOAD_MAX_BYTES=262144000
